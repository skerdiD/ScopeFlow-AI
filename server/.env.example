SECRET_KEY=replace-with-django-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,scopeflow-ai.onrender.com
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Supabase PostgreSQL (required)
# Example:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# Supabase Auth (required for backend token verification)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_AUTH_CACHE_TTL=30

# Optional database tuning
DATABASE_CONN_MAX_AGE=60
# Override only when needed (for local non-SSL PostgreSQL, use disable)
DATABASE_SSL_MODE=require

# Optional API hardening / abuse controls
DRF_THROTTLE_ANON=120/min
DRF_THROTTLE_USER=600/min
DRF_THROTTLE_GENERATE_PROPOSAL=30/hour
DRF_THROTTLE_GENERATE_TEMPLATE=30/hour
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
